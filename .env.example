# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Google AI Studio API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: which Gemini model to use for chat/text generation
GEMINI_MODEL=gemini-flash-latest

# Optional: model for image generation (if used)
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Webhook config (only needed when deployed). Leave empty for local polling.
# Example: https://your-app.onrender.com
WEBHOOK_BASE_URL=

# Port to bind on (Render sets this automatically)
PORT=8080

# A long random string. Used as part of the webhook secret path.
WEBHOOK_SECRET=
